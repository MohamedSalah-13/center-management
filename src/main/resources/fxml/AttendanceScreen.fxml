<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.text.Font?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.codejava.center.controller.AttendanceController"
            style="-fx-background-color: #f8f9fa;">

    <!-- شريط علوي -->
    <top>
        <HBox alignment="CENTER" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="شاشة الحضور والانصراف السريع" textFill="WHITE">
                <font><Font name="System Bold" size="24.0" /></font>
            </Label>
        </HBox>
    </top>

    <!-- لوحة المسح وعرض النتيجة (اليمين) -->
    <right>
        <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-padding: 30; -fx-background-color: white;" prefWidth="400.0">
            <Label text="مرر الكارنيه الآن" textFill="#7f8c8d">
                <font><Font name="System Bold" size="18.0" /></font>
            </Label>

            <!-- حقل الباركود (سيتم إخفاؤه برمجياً أو جعله شفافاً في النسخة النهائية) -->
            <TextField fx:id="barcodeScannerField" onAction="#handleBarcodeScan" promptText="استعداد للقراءة..."
                       style="-fx-font-size: 18px; -fx-alignment: center;"/>

            <Separator />

            <!-- منطقة عرض النتيجة -->
            <VBox fx:id="resultCard" alignment="CENTER" spacing="10.0" style="-fx-padding: 20; -fx-background-radius: 10;">
                <Label fx:id="studentNameLabel" text="اسم الطالب" wrapText="true" textAlignment="CENTER">
                    <font><Font name="System Bold" size="28.0" /></font>
                </Label>
                <Label fx:id="groupNameLabel" text="المجموعة">
                    <font><Font size="18.0" /></font>
                </Label>
                <Label fx:id="statusLabel" text="الحالة">
                    <font><Font name="System Bold" size="22.0" /></font>
                </Label>
            </VBox>
        </VBox>
    </right>

    <!-- جدول السجل اللحظي (اليسار) -->
    <center>
        <VBox style="-fx-padding: 20;" spacing="10.0">
            <Label text="سجل الدخول اللحظي">
                <font><Font name="System Bold" size="16.0" /></font>
            </Label>
            <TableView fx:id="attendanceLogTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colTime" text="الوقت" prefWidth="100.0" />
                    <TableColumn fx:id="colName" text="الاسم" prefWidth="250.0" />
                    <TableColumn fx:id="colStatus" text="الحالة" prefWidth="150.0" />
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>
