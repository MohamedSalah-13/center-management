<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.codejava.center.controller.LoginController">

    <VBox alignment="CENTER" spacing="15.0" styleClass="card" maxWidth="400.0">
        <Label text="تسجيل الدخول" styleClass="header-label">
            <VBox.margin><Insets bottom="10.0" /></VBox.margin>
        </Label>

        <TextField fx:id="usernameField" promptText="اسم المستخدم" styleClass="text-field" />
        <PasswordField fx:id="passwordField" promptText="كلمة المرور" styleClass="text-field" />

        <Label fx:id="errorLabel" styleClass="danger-text" visible="false" />

        <Button text="دخول" onAction="#handleLogin" defaultButton="true" maxWidth="Infinity" styleClass="button" />
    </VBox>
</VBox>