<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.codejava.center.controller.StudentRegistrationController"
      style="-fx-background-color: #f4f4f4; -fx-padding: 30;">

    <Label text="تسجيل بيانات طالب" textFill="#2c3e50">
        <font><Font name="System Bold" size="24.0" /></font>
    </Label>

    <GridPane hgap="15.0" vgap="15.0">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="100.0" />
            <ColumnConstraints hgrow="ALWAYS" minWidth="250.0" />
        </columnConstraints>

        <Label text="اسم الطالب:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="رقم الهاتف:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="phoneField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="رقم ولي الأمر:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="parentPhoneField" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label text="المرحلة الدراسية:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <ComboBox fx:id="schoolLevelCombo" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <Label text="الباركود:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <TextField fx:id="barcodeField" promptText="يترك فارغاً للتوليد التلقائي" GridPane.columnIndex="1" GridPane.rowIndex="4" />
    </GridPane>

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Button text="حفظ جديد" onAction="#handleSaveAction" style="-fx-background-color: #27ae60; -fx-text-fill: white;" />
        <Button fx:id="updateButton" text="تعديل" disable="true" onAction="#handleUpdateAction" style="-fx-background-color: #f39c12; -fx-text-fill: white;" />
        <Button fx:id="deleteButton" text="حذف" disable="true" onAction="#handleDeleteAction" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" />
        <Button text="إلغاء التحديد" onAction="#handleClearAction" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" />
    </HBox>

    <TableView fx:id="studentTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colBarcode" text="الباركود" prefWidth="120.0" />
            <TableColumn fx:id="colName" text="الاسم" prefWidth="250.0" />
            <TableColumn fx:id="colPhone" text="الهاتف" prefWidth="120.0" />
            <TableColumn fx:id="colLevel" text="المرحلة" prefWidth="150.0" />
        </columns>
    </TableView>
</VBox>